    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "24.3.1",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "eslint": "9.35.0",
    "eslint-config-next": "16.0.10",
    "typescript": "5.9.2"
  },
  "pnpm": {
