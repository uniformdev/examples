# For Uniform CLI auth
UNIFORM_API_KEY=

# Default team ID to use for Uniform CLI
UNIFORM_TEAM_ID=

# Default project ID to use for Uniform CLI
UNIFORM_PROJECT_ID=

# Cloudflare D1 (segment storage). Set all three to use real D1 via the REST API;
# leave any unset to fall back to the local SQLite mock at ./.data/segments.sqlite.
# API token needs the account-scoped "D1 Edit" permission.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=
