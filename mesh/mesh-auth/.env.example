# Uniform API hosts
UNIFORM_API_HOST=
UNIFORM_EDGE_API_HOST=

# Identity delegation credentials (from Uniform dashboard > Custom Integrations)
UNIFORM_INTEGRATION_ID=
UNIFORM_INTEGRATION_SECRET=

# Cookie encryption secret (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESH_SESSION_SECRET=

# CSRF guard for BFF routes (Origin allow-list + `X-Mesh-Csrf` constant header).
# Allowed origins for this mesh app (the iframe origin). Comma-separated, HTTPS only.
# Do NOT enable permissive CORS on `/api/session`, `/api/status`, or other guarded routes —
# the CSRF header check depends on browsers blocking custom headers cross-origin.
MESH_ALLOWED_ORIGINS=https://localhost:9002
