{
  "name": "mesh-build-publish-vanilla-example",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "predev": "pnpm run build",
    "dev": "HTTPS=1 node --env-file=.env --watch src/server.js",
    "start": "node src/server.js",
    "build": "esbuild client/delegation-bootstrap.js --bundle --outfile=public/delegation-bootstrap.js --format=iife --platform=browser --sourcemap",
    "lint": "eslint \"{src,client}/**/*.{js,mjs}\"",
    "test": "node --test src/*.test.js"
  },
  "dependencies": {
    "@uniformdev/canvas": "20.50.2-alpha.77",
    "@uniformdev/mesh-identity-delegation-session": "20.50.2-alpha.77",
    "@uniformdev/mesh-sdk": "20.50.2-alpha.77",
    "express": "4.20.0",
    "htmx.org": "4.0.0-beta2",
    "selfsigned": "2.4.1"
  },
  "devDependencies": {
    "esbuild": "0.25.8"
  }
}
