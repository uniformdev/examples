# Uniform API hosts
UNIFORM_API_HOST=https://uniform.app
UNIFORM_EDGE_API_HOST=https://uniform.global

# Identity delegation credentials (from Uniform dashboard > Custom Integrations)
UNIFORM_INTEGRATION_ID=
UNIFORM_INTEGRATION_SECRET=

# Cookie encryption secret (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESH_SESSION_SECRET=

# Optional: override default port (9003)
# PORT=9003

# HTTPS — `npm run dev` sets HTTPS=1. If HTTPS_KEY/HTTPS_CERT are unset, the server
# generates a one-off self-signed cert for this run. Set both to PEM paths
# (e.g. from mkcert) to use your own certificate files.
# HTTPS=1
# HTTPS_KEY=./certs/localhost-key.pem
# HTTPS_CERT=./certs/localhost-cert.pem
