# Uniform API hosts
UNIFORM_API_HOST=
UNIFORM_EDGE_API_HOST=

# Identity delegation credentials (from Uniform dashboard > Custom Integrations)
UNIFORM_INTEGRATION_ID=
UNIFORM_INTEGRATION_SECRET=

# Cookie encryption secret (min 32 chars).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESH_SESSION_SECRET=

# Strictening security against CSRF attacks
# Allowed origins for the mesh app to call the token exchange endpoint
# This is the origin of the mesh app iframe
# Use "https://project-lq3uv.vercel.app" for deployed one
MESH_ALLOWED_ORIGINS=https://localhost:9002
